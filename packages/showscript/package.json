{
  "name": "@showrun/showscript",
  "version": "0.1.0",
  "description": "ShowScript DSL parser for ShowRun browser automation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:grammar": "peggy --format es -o src/generated-parser.js src/grammar.pegjs",
    "build": "pnpm build:grammar && tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "peggy": "^5.0.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "author": "ShowRun <developers@showrun.co>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/useshowrun/showrun.git",
    "directory": "packages/showscript"
  },
  "homepage": "https://github.com/useshowrun/showrun",
  "bugs": {
    "url": "https://github.com/useshowrun/showrun/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
